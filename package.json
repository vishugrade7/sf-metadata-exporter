{
  "name": "sf-metadata-exporter",
  "displayName": "Salesforce Metadata Exporter",
  "description": "Fastest Salesforce metadata exporter with advanced filters.",
  "version": "1.1.35",
  "icon": "icon.png",
  "publisher": "vishugrade7",
  "repository": {
    "type": "git",
    "url": "https://github.com/vishugrade7/sf-metadata-exporter"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:sf-metadata-exporter.open"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "sf-metadata-exporter.open",
        "title": "SF Metadata Exporter: Open"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "node ./esbuild.config.mjs",
    "watch": "node ./esbuild.config.mjs --watch",
    "typecheck": "tsc -p ./ --noEmit"
  },
  "devDependencies": {
    "@types/jsforce": "^1.11.6",
    "@types/node": "18.x",
    "@types/vscode": "^1.80.0",
    "@vscode/vsce": "^3.9.1",
    "esbuild": "^0.28.0",
    "typescript": "^5.1.3"
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^6.7.2",
    "@vscode/codicons": "^0.0.43",
    "jsforce": "^1.11.1"
  }
}
